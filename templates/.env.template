# .env file format: v4
# ==========================================
# BOSE SOUNDTOUCH HYBRID SERVER SETTINGS
# ==========================================
# NOTE ON IP ADDRESSES:
# If you are running Music Assistant and this Hybrid App on the 
# same NAS/Server, # MASS_IP and APP_IP are the EXACT SAME IP address.
#
# If Music Assistant runs as a Home Assistant add-on, 
# MASS_IP must be# the IP address of HOME ASSISTANT 
# ---------------------------------------------------------------

# REQUIRED: The local IP address of this NAS/Server (e.g., 192.168.1.10)
# APP_PORT defaults to 3000 Change only if you have a port conflict.

APP_IP=
APP_PORT=3000


# REQUIRED: The local IP address of Music Assistant Server
# MASS_PORT defaults to 8095. Change only if you customized it in Music Assistant.
# Provide either MASS_TOKEN, OR MASS_USERNAME and MASS_PASSWORD, Both are not required.
# - MASS_TOKEN: a pre-issued Music Assistant auth token
# - MASS_USERNAME/MASS_PASSWORD: Music Assistant login
# Note: If password contains special characters like # or &, you MUST
# add quotation marks around it like this: MASS_PASSWORD="password#example"

MASS_IP=
MASS_PORT=8095
MASS_TOKEN=
MASS_USERNAME=
MASS_PASSWORD=


# MASS DOCKER RESTART SETTINGS
# The exact container name of your Music Assistant instance.
# - Standalone Docker: usually 'music-assistant-server' or whatever you named it
# - Music Assistant running inside Home Assistant:
#   1. Click "Music Assistant" in the Home Assistant sidebar.
#   2. The browser's address bar will look like this.
#      http://<your-ha-ip>:8123/d5369777_music_assistant
#   3. Copy everything after port number and slash — that's your container name.
#   Example: MASS_CONTAINER_NAME=d5369777_music_assistant

MASS_CONTAINER_NAME=music-assistant-server

# HA_TOKEN (optional) — Home Assistant long-lived access token.
# only required when HA/MA runs on a seperate VM from Hybrid app

HA_TOKEN=
HA_PORT=8123

# ==============================================================================
# SYSTEM & NETWORK FIXES
# ==============================================================================

# BOSE HARDWARE SETTINGS
# 8090 Standard SoundTouch hardware port. Do not change unless port-forwarding.
BOSE_PORT=8090

# REVERSE PROXY
# Set to 'true' ONLY if you run this behind Nginx Proxy Manager, Traefik, Cloudflare, etc.
# This ensures the server reads the Speaker's real IP, not the Proxy's IP.
TRUST_PROXY=false