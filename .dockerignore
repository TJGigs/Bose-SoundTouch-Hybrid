# .dockerignore
# Everything in here is excluded from the Docker build context.
# Smaller context = faster builds, smaller images, no secrets leaked.

# --- Git history (never needed in a container) ---
.git/
.gitignore

# --- Secrets (never bake these into an image) ---
.env
.env.*

# --- Node modules (Dockerfile installs fresh ones via npm ci) ---
node_modules/
package-lock.json

# --- User config (volume-mounted at runtime via YAML) ---
config/

# --- Logs (written at runtime, belong on host via volume mount) ---
logs/
*.log
npm-debug.log

# --- Dev/test artifacts ---
testscripts/
Misc/
misc/
examples/
.backups/
.history/

# --- CI/CD (not needed at runtime) ---
.github/

# --- Personal local-only compose file & dev scripts (Windows-only, not needed in image) ---
local-bose-soundtouch-hybrid.yml
Set-FileDates.ps1
SetReleaseDates.bat

# --- HA add-on store metadata (not used by the standalone image) ---
repository.yaml

# --- Documentation (not needed in runtime image) ---
Docs/
docs/
README.md
CHANGELOG.md

# --- AI workflow files ---
claude.md
CLAUDE.md
.claude/

# --- Push staging clone (GitHub Desktop-tracked, refreshed from this dev
# folder before each push) — not source, and would bloat a local test build ---
Bose-SoundTouch-Hybrid-Push-Staging/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor/IDE ---
.vscode/
*.code-workspace
